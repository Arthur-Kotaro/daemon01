# .clang-format
BasedOnStyle: LLVM
IndentWidth: 4
TabWidth: 4
UseTab: Never
ColumnLimit: 100
AllowShortFunctionsOnASingleLine: Inline
BreakBeforeBraces: Attach
DerivePointerAlignment: false
PointerAlignment: Left
SortIncludes:     true
IncludeBlocks:    Preserve


#BasedOnStyle: LLVM
#IndentWidth: 4
#TabWidth: 4
#UseTab: Never
#ColumnLimit: 100
#AllowShortFunctionsOnASingleLine: Empty
#DerivePointerAlignment: false
#PointerAlignment: Left
#SortIncludes: CaseSensitive